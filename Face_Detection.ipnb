    {
      "cell_type": "code",
      "source": [
        "import cv2\n",
        "from matplotlib import pyplot as plt\n",
        "from google.colab import files"
      ],
      "metadata": {
        "id": "GiPIJ6ZUykoW"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "image_file='/content/arthana_binu_photos_2501160214_035.jpg'\n",
        "image=cv2.imread(image_file)"
      ],
      "metadata": {
        "id": "uB4tEbYQzTMO"
      },
      "execution_count": 29,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "image=cv2.imread(image_file)\n",
        "image_rgb=cv2.cvtColor(image,cv2.COLOR_BGR2RGB)\n",
        "#convert for proper display\n",
        "\n",
        "#cv2.imread->reads the image as an array(open works with array)\n",
        "#openCV reads BGR fromat by default.But matplotlib uses RGB format,so we convert it\n"
      ],
      "metadata": {
        "id": "MlWoWSdIzhSF"
      },
      "execution_count": 30,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "!wget -O haar_face.xml https://raw.githubusercontent.com/opencv/opencv/master/data/haarcascades/haarcascade_frontalface_default.xml\n",
        "face_cascade = cv2.CascadeClassifier('haar_face.xml')\n",
        "\n",
        "#wget -> cimmand-line tool to download files from the internet.\n",
        "# -O haa_face.xml ->save the download file locally with the name haar_face.xml\n",
        "#The URL ->pout to opencv's pre trained haar cascade file for frontal face detection\n",
        "#haar cascade -> pre-trained model to detect faces\n",
        "#CascadeClassifier()-> load load the model so we can use it"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "wAhu8BTg1one",
        "outputId": "74d17260-8524-4ca2-ceb9-65f574df40d8"
      },
      "execution_count": 31,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "--2026-03-13 06:59:15--  https://raw.githubusercontent.com/opencv/opencv/master/data/haarcascades/haarcascade_frontalface_default.xml\n",
            "Resolving raw.githubusercontent.com (raw.githubusercontent.com)... 185.199.110.133, 185.199.108.133, 185.199.111.133, ...\n",
            "Connecting to raw.githubusercontent.com (raw.githubusercontent.com)|185.199.110.133|:443... connected.\n",
            "HTTP request sent, awaiting response... 200 OK\n",
            "Length: 930127 (908K) [text/plain]\n",
            "Saving to: ‘haar_face.xml’\n",
            "\n",
            "\rhaar_face.xml         0%[                    ]       0  --.-KB/s               \rhaar_face.xml       100%[===================>] 908.33K  --.-KB/s    in 0.05s   \n",
            "\n",
            "2026-03-13 06:59:15 (17.6 MB/s) - ‘haar_face.xml’ saved [930127/930127]\n",
            "\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n",
        "\n",
        "#Face detection works faster and better on grayscale images\n",
        "#No need to check 3 color channels (RGB) for detection"
      ],
      "metadata": {
        "id": "bdO5Yg6kDNkJ"
      },
      "execution_count": 32,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "faces = face_cascade.detectMultiScale(gray,scaleFactor=1.1, minNeighbors=5)\n",
        "\n",
        "#dectMultScale() ->scans image to find faces\n",
        "#scaleFactor=1.1 -> image sacle changes slightly each step\n",
        "#minNeighbors=5 ->minimum rectangle to confirm a face"
      ],
      "metadata": {
        "id": "dkfp2kBODqBD"
      },
      "execution_count": 33,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "for(x,y,w,h) in faces:\n",
        "  cv2.rectangle(image_rgb,(x,y),(x+w,y+h),(255,0,0),2)\n"
      ],
      "metadata": {
        "id": "uBqQyQkoErFL"
      },
      "execution_count": 35,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "plt.figure(figsize=(8,6))\n",
        "plt.imshow(image_rgb)\n",
        "plt.title(f'Faces detected: {len(faces)}')\n",
        "plt.axis('off')\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 521
        },
        "id": "uvY0EBtWGIiz",
